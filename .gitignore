*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo
.python-version

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python packaging / cache / test
.Python
build/
dist/
.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.coverage
