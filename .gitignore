node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tsbuildinfo

# Frontend build / cache
coverage/
.next/
.nuxt/
.svelte-kit/
.parcel-cache/
.cache/

